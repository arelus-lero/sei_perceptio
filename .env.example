# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# === LLM ===
LLM_API_URL=https://<llm-endpoint>/v1/chat/completions
LLM_API_KEY=<api-key>
LLM_MODEL=maritalk-7b  # ou modelo nacional PBIA
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
# Gemini thinking: reasoning_effort=none desliga raciocínio (OpenAI-compat). Omitir para outros provedores.
# LLM_REASONING_EFFORT=none
# Fallback Gemini 2.5: LLM_THINKING_BUDGET=0
LLM_TIMEOUT_MS=15000
LLM_TTFT_TIMEOUT_MS=5000

# === Embeddings (Edge Function interna) ===
EMBED_MODEL=gte-small
EMBED_FUNCTION_URL=http://localhost:54321/functions/v1/embed  # local dev
# EMBED_FUNCTION_URL=https://<project-id>.supabase.co/functions/v1/embed  # prod

# === Autenticação ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_EXPIRY=3600  # 1 hora

# === Seed (service_role — apenas scripts/seed) ===
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# RNF-005: preferir pooler local (porta 54329) ou Supavisor em produção
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54329/postgres
SUPABASE_STORAGE_BUCKET_DOCUMENTS=documentos
SUPABASE_STORAGE_BUCKET_EXPORTS=exportacoes

# === Teste de carga (RNF-005) ===
# LOAD_TEST_EMAIL=
# LOAD_TEST_PASSWORD=
# LOAD_TEST_NOTEBOOK_ID=
# LOAD_TEST_BASE_URL=http://localhost:3000
# A11Y_BASE_URL=http://localhost:3000  # base URL para npm run a11y:axe

# === OCR (RF-004 / RNF-002) ===
OCR_LANGUAGE=por
OCR_MIN_CHARS_PER_PAGE=30
OCR_MAX_PAGES=100
OCR_PDF_RENDER_SCALE=2
OCR_CONCURRENCY=4

# === Anonimização (RF-006) ===
ANONYMIZATION_MODE=mask  # mask | redact | remove
ANONYMIZATION_PII_TYPES=CPF,CNPJ,EMAIL,TELEFONE,ENDERECO,DADOS_BANCARIOS,DADOS_SENSIVEIS
# PRESIDIO_ANALYZER_URL=http://localhost:5002
# SPACY_NER_URL=http://localhost:8000

# === Bloqueio sigiloso (RF-042) ===
# SIGILO_DPO_EXCEPTION_ORGAO_IDS=<uuid-orgao-autorizado>

# === Inngest (agendamento) ===
INNGEST_EVENT_KEY=<event-key>
INNGEST_SIGNING_KEY=<signing-key>

# === Notificações externas (RF-024) ===
NOTIFICATION_EMAIL_PROVIDER=resend  # resend | smtp
NOTIFICATION_FROM_EMAIL=alertas@example.gov.br
RESEND_API_KEY=<resend-api-key>
# SMTP_HOST=smtp.example.gov.br
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# === Google OAuth (opcional) ===
GOOGLE_CLIENT_ID=<client-id>
GOOGLE_CLIENT_SECRET=<client-secret>
